# Copy to .env.local and fill in. NEVER commit the real values.
# Pull from Vercel after `vercel link`:  vercel env pull .env.local

# Supabase project (Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only; bypasses RLS

# Shared secret that unlocks the upload form
UPLOAD_SHARED_SECRET=choose-a-long-random-string

# Optional overrides (defaults shown)
# UPLOAD_MAX_BYTES=2000000
