{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/skills.json",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/api/skills",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=30, stale-while-revalidate=300" }
      ]
    }
  ]
}
